---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Lamina POP — Una nueva ola de construcción',
  description = 'Vivienda digna, asequible y rápida de construir. Desde 2004, Lamina POP construye casas, escuelas y espacios comunitarios con lámina corrugada plegada y remaches POP.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="bg-paper text-ink antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FFFFFF" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
    />
  </head>
  <body class="bg-paper text-ink font-sans font-medium selection:bg-pop selection:text-ink">
    <!-- Page-wide grid background -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-0 opacity-[0.045]"
      style="background-image: linear-gradient(#000 1px, transparent 1px), linear-gradient(90deg, #000 1px, transparent 1px); background-size: 64px 64px;"
    ></div>
    <slot />
  </body>
</html>
<style is:global>
  :root { color-scheme: light; }
  html { scroll-behavior: auto; }
  /* Page load fade-in */
  body { animation: pageIn 0.55s 0.05s ease-out both; }
  @keyframes pageIn { from { opacity: 0; } to { opacity: 1; } }
  body { overflow-x: hidden; }
  /* Hide content not in active language */
  [data-lang].hidden { display: none !important; }
  /* Type scale */
  .h-display {
    font-family: 'Space Grotesk', Inter, sans-serif;
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.95;
  }
  .eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6B6B6B;
  }
  .pop-bar {
    background: linear-gradient(90deg, #FFD600 0%, #FFD600 100%);
  }
  /* Smooth scroll suppression for Lenis */
  html.lenis,
  html.lenis body { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto !important; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .lenis.lenis-scrolling iframe { pointer-events: none; }
</style>
