---
const links = [
  { href: '#crisis',   es: 'Problema',  en: 'Problem'  },
  { href: '#solution', es: 'Solución',  en: 'Solution' },
  { href: '#projects', es: 'Proyectos', en: 'Projects' },
  { href: '#contact',  es: 'Contacto',  en: 'Contact'  },
];
---

<!--
  Sticky nav. Hidden above the fold; slides in after 80px of scroll.
  Contains a 2px yellow progress bar at the bottom edge.
  Active section is tracked in main.ts via ScrollTrigger + .is-active class.
  z-40 so the LangToggle (z-50) floats on top naturally as the right-side button.
-->
<nav
  id="site-nav"
  class="fixed inset-x-0 top-0 z-40 will-change-transform"
  style="transition: transform 0.45s cubic-bezier(0.16,1,0.3,1);"
  aria-label="Main navigation"
>
  <!-- Frosted backdrop -->
  <div class="absolute inset-0 border-b border-black/8 bg-white/94 backdrop-blur-md"></div>

  <!-- Scroll progress bar -->
  <div
    id="nav-progress"
    class="absolute bottom-0 left-0 h-[2.5px] w-0 bg-pop"
    style="transition: none; transform-origin: left;"
  ></div>

  <div class="relative mx-auto flex h-[52px] max-w-[1400px] items-center justify-between px-6">

    <!-- Logomark + wordmark -->
    <a href="#" class="shrink-0" aria-label="Lamina POP — volver al inicio">
      <img src="/projects/p02.png" alt="Lamina POP" class="h-[50px] w-auto" />
    </a>

    <!-- Section links (desktop only) -->
    <ol class="hidden items-center gap-6 md:flex" role="list">
      {links.map(l => (
        <li>
          <a
            href={l.href}
            data-target={l.href.slice(1)}
            data-i18n="t"
            class="nav-link group relative py-2 text-[10px] font-semibold uppercase tracking-[0.16em] text-muted transition-colors duration-200 hover:text-ink [&.is-active]:text-ink"
          >
            <span data-lang="es">{l.es}</span>
            <span data-lang="en" class="hidden">{l.en}</span>
            <!-- underline indicator -->
            <span
              aria-hidden="true"
              class="absolute inset-x-0 bottom-0 h-[2px] origin-left scale-x-0 bg-pop transition-transform duration-300 group-hover:scale-x-100 [.is-active_&]:scale-x-100"
            ></span>
          </a>
        </li>
      ))}
    </ol>

    <!-- Space reserved for the floating LangToggle pill (z-50, top-5 right-5) -->
    <div class="hidden w-16 shrink-0 md:block" aria-hidden="true"></div>
  </div>
</nav>
