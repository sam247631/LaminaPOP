---
const items = [
  {
    n: '01',
    es: { k: 'Salud', v: 'Enfermedades respiratorias, infecciones y mortalidad infantil aumentan en viviendas precarias.' },
    en: { k: 'Health', v: 'Respiratory disease, infections and child mortality rise sharply in precarious housing.' },
  },
  {
    n: '02',
    es: { k: 'Educación', v: 'Niños sin un espacio adecuado para estudiar abandonan la escuela en mayor proporción.' },
    en: { k: 'Education', v: 'Children without a proper place to study drop out of school at higher rates.' },
  },
  {
    n: '03',
    es: { k: 'Economía', v: 'Familias destinan hasta el 50% de sus ingresos a alquileres informales o reparaciones constantes.' },
    en: { k: 'Economy', v: 'Families spend up to 50% of their income on informal rents or constant repairs.' },
  },
  {
    n: '04',
    es: { k: 'Resiliencia', v: 'Cada terremoto, huracán o inundación destruye lo poco construido y reinicia el ciclo.' },
    en: { k: 'Resilience', v: 'Every earthquake, hurricane or flood destroys what was built and restarts the cycle.' },
  },
];
---
<section
  id="effects"
  data-section="effects"
  data-dots="line"
  class="relative z-20 w-full py-32 md:py-48"
>
  <div class="mx-auto grid max-w-[1400px] grid-cols-1 gap-16 px-6 md:grid-cols-12 md:gap-20">
    <div class="md:col-span-5 md:sticky md:top-24 md:self-start">
      <p class="eyebrow mb-6" data-i18n="t">
        <span data-lang="es">02 — Efectos en cadena</span>
        <span data-lang="en" class="hidden">02 — Ripple effects</span>
      </p>
      <h2 class="h-display text-[clamp(2rem,4.5vw,4rem)]">
        <span data-i18n="t">
          <span data-lang="es">La crisis de vivienda no termina en las paredes.</span>
          <span data-lang="en" class="hidden">The housing crisis doesn't stop at the walls.</span>
        </span>
      </h2>
      <p class="mt-6 max-w-md font-semibold text-ink" data-i18n="t">
        <span data-lang="es">Cuando una familia no tiene un techo digno, las consecuencias se extienden a la salud, la educación y la economía durante generaciones.</span>
        <span data-lang="en" class="hidden">When a family lacks a dignified roof, the consequences spread to health, education, and the economy for generations.</span>
      </p>
    </div>

    <ol class="md:col-span-7 md:col-start-6">
      {items.map((it) => (
        <li class="effect-item border-t border-line py-10 first:border-t-0">
          <div class="flex items-baseline gap-6">
            <span class="text-xs font-semibold tracking-[0.18em] text-muted">{it.n}</span>
            <div>
              <h3 class="h-display text-2xl md:text-3xl">
                <span data-i18n="t">
                  <span data-lang="es">{it.es.k}</span>
                  <span data-lang="en" class="hidden">{it.en.k}</span>
                </span>
              </h3>
              <p class="mt-3 max-w-xl font-semibold text-ink" data-i18n="t">
                <span data-lang="es">{it.es.v}</span>
                <span data-lang="en" class="hidden">{it.en.v}</span>
              </p>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
