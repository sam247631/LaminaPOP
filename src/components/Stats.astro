---
const stats = [
  { value: 52,  suffix: '',  es: 'Estructuras construidas',                    en: 'Structures built'                  },
  { value: 300, suffix: '+', es: 'Personas beneficiadas',                      en: 'People benefited'                  },
  { value: 40,   suffix: '%', es: 'Menos costo que construcción convencional',  en: 'Less than conventional construction' },
  { value: 72,   suffix: 'h', es: 'Tiempo promedio de construcción',            en: 'Average build time'                },
];
---

<section
  id="stats"
  class="relative z-20 w-full bg-ink py-20 text-paper md:py-28"
>
  <div class="mx-auto max-w-[1400px] px-6">
    <div class="grid grid-cols-2 gap-x-6 gap-y-14 md:grid-cols-4 md:gap-x-12">
      {stats.map((s) => (
        <div class="stat-item">
          <p class="h-display flex items-baseline gap-0.5 text-[clamp(2.8rem,6vw,5.5rem)] leading-none text-pop">
            <span class="stat-number" data-target={s.value}>0</span><span>{s.suffix}</span>
          </p>
          <div class="mt-1 h-px w-8 bg-pop/40"></div>
          <p class="mt-3 text-sm leading-snug text-paper/55" data-i18n="t">
            <span data-lang="es">{s.es}</span>
            <span data-lang="en" class="hidden">{s.en}</span>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
