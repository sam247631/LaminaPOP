---
const steps = [
  {
    n: '01',
    es: { k: 'La lámina', v: 'Hojas de zinc o acero galvanizado, disponibles en cualquier país. La materia prima de medio mundo, listada en cualquier ferretería rural.' },
    en: { k: 'The sheet', v: 'Zinc or galvanized steel sheets, available in any country. The raw material of half the world, stocked in any rural hardware store.' },
  },
  {
    n: '02',
    es: { k: 'El pliegue', v: 'La lámina se dobla en forma de onda — como un acordeón — para convertirse en una membrana estructural ligera y resistente.' },
    en: { k: 'The fold', v: 'The sheet folds into a wave — like an accordion — turning into a light, resistant structural membrane.' },
  },
  {
    n: '03',
    es: { k: 'El remache POP', v: 'Une los pliegues sin soldadura ni mano de obra especializada. Un taladro y un brazo: la comunidad construye su propia casa.' },
    en: { k: 'The POP rivet', v: 'Joins the folds without welding or specialized labor. A drill and an arm: the community builds its own house.' },
  },
  {
    n: '04',
    es: { k: 'El ensamble', v: 'Cimientos ligeros, paredes plegadas, techo de lámina. Casas en pie en días — no meses.' },
    en: { k: 'The assembly', v: 'Light foundations, folded walls, sheet roof. Houses standing in days — not months.' },
  },
];
---

<section
  id="solution"
  data-section="solution"
  data-dots="logo"
  class="relative z-20 w-full py-32 md:py-48"
>
  <div class="mx-auto max-w-[1400px] px-6">
    <div class="mb-20 max-w-3xl">
      <p class="eyebrow mb-6" data-i18n="t">
        <span data-lang="es">03 — La solución</span>
        <span data-lang="en" class="hidden">03 — The solution</span>
      </p>
      <h2 class="h-display text-[clamp(2.25rem,5.5vw,5rem)]">
        <span data-i18n="t">
          <span data-lang="es">Una casa. <span class="bg-pop px-2">Dos materiales.</span> Días de construcción.</span>
          <span data-lang="en" class="hidden">One house. <span class="bg-pop px-2">Two materials.</span> Days to build.</span>
        </span>
      </h2>
      <p class="mt-6 text-muted md:text-lg" data-i18n="t">
        <span data-lang="es">Lámina corrugada plegada en onda + remaches POP. Una membrana estructural ligera, fuerte y replicable por cualquier comunidad.</span>
        <span data-lang="en" class="hidden">Corrugated metal sheet folded into waves + POP rivets. A structural membrane that is light, strong, and replicable by any community.</span>
      </p>
    </div>

    <div class="max-w-2xl">
      <ol>
        {steps.map((s, i) => (
          <li class="solution-step border-t border-line py-12 first:border-t-0" data-step={i}>
            <div class="flex items-baseline gap-6">
              <span class="text-xs font-semibold tracking-[0.18em] text-muted">{s.n}</span>
              <div>
                <h3 class="h-display text-3xl md:text-4xl">
                  <span data-i18n="t">
                    <span data-lang="es">{s.es.k}</span>
                    <span data-lang="en" class="hidden">{s.en.k}</span>
                  </span>
                </h3>
                <p class="mt-3 max-w-md text-muted" data-i18n="t">
                  <span data-lang="es">{s.es.v}</span>
                  <span data-lang="en" class="hidden">{s.en.v}</span>
                </p>
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
