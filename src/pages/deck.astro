---
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Lamina POP — Investor Deck</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #0A0A0A;
      --paper: #FFFFFF;
      --pop: #FFD600;
      --muted: #6B6B6B;
      --line: #E5E5E5;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--paper);
      color: var(--ink);
      line-height: 1.5;
    }

    /* ── Slide base ── */
    .slide {
      min-height: 100svh;
      width: 100%;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 5rem 2rem;
    }

    .inner {
      width: 100%;
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ── Typography ── */
    .display {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.03em;
    }

    .eyebrow {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }

    .eyebrow.light { color: rgba(255,255,255,0.4); }

    .tag {
      display: inline-block;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      border: 1px solid var(--pop);
      color: var(--pop);
      padding: 0.35rem 0.9rem;
      border-radius: 999px;
    }

    .tag.dim {
      border-color: rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.5);
    }

    /* ── Slide 1: Cover ── */
    #s1 {
      background: var(--pop);
      position: relative;
      overflow: hidden;
    }

    #s1 .inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    #s1 h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-weight: 700;
      font-size: clamp(4rem, 10vw, 9rem);
      line-height: 0.88;
      letter-spacing: -0.04em;
      color: var(--ink);
    }

    #s1 .right {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    #s1 .tagline {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(1.25rem, 2.5vw, 2rem);
      font-weight: 600;
      color: var(--ink);
      line-height: 1.15;
    }

    #s1 .meta {
      font-size: 0.8125rem;
      color: rgba(0,0,0,0.5);
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    #s1 .slide-num {
      position: absolute;
      bottom: 2rem;
      right: 2rem;
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.3);
    }

    /* ── Slide 2: Mission ── */
    #s2 { background: var(--ink); color: var(--paper); }

    #s2 .mission-text {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(1.75rem, 4vw, 3.5rem);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.02em;
      max-width: 900px;
    }

    #s2 .mission-text em {
      font-style: normal;
      color: var(--pop);
    }

    #s2 .tags { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 3rem; }

    /* ── Slide 3: Crisis ── */
    #s3 { padding: 0; position: relative; overflow: hidden; }

    #s3 .crisis-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: brightness(0.35);
    }

    #s3 .inner {
      position: relative;
      z-index: 1;
      padding: 5rem 2rem;
      color: var(--paper);
    }

    #s3 h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 6vw, 5.5rem);
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.03em;
      max-width: 800px;
      margin-bottom: 2rem;
    }

    #s3 h2 mark {
      background: var(--pop);
      color: var(--ink);
      padding: 0 0.15em;
    }

    #s3 .crisis-body {
      max-width: 560px;
      font-size: 1.125rem;
      color: rgba(255,255,255,0.75);
      margin-bottom: 4rem;
    }

    #s3 .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      border-top: 1px solid rgba(255,255,255,0.15);
      padding-top: 2.5rem;
    }

    #s3 .stat-val {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      color: var(--pop);
      line-height: 1;
    }

    #s3 .stat-label {
      font-size: 0.8125rem;
      color: rgba(255,255,255,0.5);
      margin-top: 0.5rem;
    }

    /* ── Slide 4: System ── */
    #s4 { background: var(--paper); }

    #s4 .system-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
      margin-top: 3rem;
    }

    #s4 .steps { display: flex; flex-direction: column; gap: 0; }

    #s4 .step {
      border-top: 1px solid var(--line);
      padding: 1.75rem 0;
    }

    #s4 .step:last-child { border-bottom: 1px solid var(--line); }

    #s4 .step-num {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    #s4 .step h3 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    #s4 .step p { font-size: 0.9375rem; color: var(--muted); max-width: 380px; }

    #s4 .system-img {
      width: 100%;
      border-radius: 2px;
      display: block;
    }

    /* ── Slide 5: Why ── */
    #s5 { background: var(--ink); color: var(--paper); }

    #s5 h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin-bottom: 4rem;
    }

    #s5 h2 span { color: var(--pop); }

    #s5 .why-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
      border: 1px solid rgba(255,255,255,0.1);
    }

    #s5 .why-item {
      padding: 2.5rem;
      border-right: 1px solid rgba(255,255,255,0.1);
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }

    #s5 .why-item:nth-child(2n) { border-right: none; }
    #s5 .why-item:nth-child(3),
    #s5 .why-item:nth-child(4) { border-bottom: none; }

    #s5 .why-label {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--pop);
      margin-bottom: 1rem;
    }

    #s5 .why-val {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700;
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    #s5 .why-desc { font-size: 0.9375rem; color: rgba(255,255,255,0.55); }

    /* ── Slide 6: What we build ── */
    #s6 { background: var(--paper); }

    #s6 h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.25rem, 5vw, 4.5rem);
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.03em;
      margin-bottom: 3rem;
    }

    #s6 .build-img {
      width: 100%;
      display: block;
      border-radius: 2px;
      margin-bottom: 3rem;
    }

    #s6 .build-types {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
      border-top: 1px solid var(--line);
      padding-top: 2rem;
    }

    #s6 .build-type {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      font-weight: 600;
    }

    #s6 .build-type span {
      display: block;
      width: 2rem;
      height: 2px;
      background: var(--pop);
      margin-bottom: 0.75rem;
    }

    /* ── Slide 7: Traction ── */
    #s7 { background: var(--pop); }

    #s7 h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.25rem, 5vw, 4rem);
      font-weight: 700;
      line-height: 0.95;
      letter-spacing: -0.03em;
      color: var(--ink);
      margin-bottom: 4rem;
    }

    #s7 .traction-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem;
    }

    #s7 .t-item { border-top: 2px solid rgba(0,0,0,0.2); padding-top: 1.5rem; }

    #s7 .t-val {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      color: var(--ink);
      line-height: 1;
    }

    #s7 .t-label {
      font-size: 0.8125rem;
      font-weight: 600;
      color: rgba(0,0,0,0.55);
      margin-top: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    #s7 .partner-row {
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(0,0,0,0.15);
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    #s7 .partner-label {
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.45);
    }

    #s7 .partner-name {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--ink);
    }

    /* ── Slide 8: Closing ── */
    #s8 { padding: 0; position: relative; overflow: hidden; }

    #s8 .closing-photo {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      filter: brightness(0.25);
    }

    #s8 .inner {
      position: relative;
      z-index: 1;
      padding: 5rem 2rem;
      color: var(--paper);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 100svh;
    }

    #s8 h2 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 8vw, 7rem);
      font-weight: 700;
      line-height: 0.92;
      letter-spacing: -0.04em;
      max-width: 800px;
    }

    #s8 h2 em {
      font-style: normal;
      color: var(--pop);
    }

    #s8 .closing-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 2rem;
      border-top: 1px solid rgba(255,255,255,0.15);
      padding-top: 2rem;
    }

    #s8 .contact-email {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--pop);
      text-decoration: none;
    }

    #s8 .contact-email:hover { text-decoration: underline; }

    #s8 .contact-web {
      font-size: 0.9375rem;
      color: rgba(255,255,255,0.5);
    }

    /* ── Nav dots ── */
    .nav-dots {
      position: fixed;
      right: 1.5rem;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      z-index: 100;
    }

    .nav-dots a {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: rgba(0,0,0,0.25);
      display: block;
      transition: background 0.2s, transform 0.2s;
    }

    .nav-dots a.active,
    .nav-dots a:hover { background: var(--ink); transform: scale(1.5); }

    .nav-dots.light a { background: rgba(255,255,255,0.3); }
    .nav-dots.light a.active,
    .nav-dots.light a:hover { background: var(--pop); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      #s1 .inner { grid-template-columns: 1fr; gap: 2rem; }
      #s4 .system-grid { grid-template-columns: 1fr; }
      #s5 .why-grid { grid-template-columns: 1fr; }
      #s5 .why-item { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.1) !important; }
      #s5 .why-item:last-child { border-bottom: none !important; }
      #s6 .build-types { grid-template-columns: repeat(2, 1fr); }
      #s7 .traction-grid { grid-template-columns: repeat(2, 1fr); }
      #s3 .stats-row { grid-template-columns: 1fr; gap: 1.5rem; }
    }
  </style>
</head>
<body>

  <!-- Nav dots -->
  <nav class="nav-dots" id="navdots" aria-label="Slide navigation">
    <a href="#s1" title="Cover"></a>
    <a href="#s2" title="Mission"></a>
    <a href="#s3" title="The Crisis"></a>
    <a href="#s4" title="Our System"></a>
    <a href="#s5" title="Why Lamina POP"></a>
    <a href="#s6" title="What We Build"></a>
    <a href="#s7" title="Traction"></a>
    <a href="#s8" title="Contact"></a>
  </nav>

  <!-- ── Slide 1: Cover ── -->
  <section class="slide" id="s1">
    <div class="inner">
      <div>
        <h1>LAMINA<br>POP</h1>
      </div>
      <div class="right">
        <p class="tagline">We build dignified,<br>safe, and accessible<br>housing.</p>
        <p class="meta">Investor Deck · 2025</p>
      </div>
    </div>
    <span class="slide-num">01 / 08</span>
  </section>

  <!-- ── Slide 2: Mission ── -->
  <section class="slide" id="s2">
    <div class="inner">
      <p class="eyebrow light">02 — Mission</p>
      <p class="mission-text">
        Our mission is to increase access to <em>low-cost, dignified shelter worldwide</em>. Our patented construction system produces safer, healthier, and more accessible housing at a fraction of the cost and time of current solutions.
      </p>
      <div class="tags">
        <span class="tag">Impact investment</span>
        <span class="tag dim">Strategic partnerships</span>
        <span class="tag dim">Community projects</span>
      </div>
    </div>
  </section>

  <!-- ── Slide 3: The Crisis ── -->
  <section class="slide" id="s3">
    <img src="/deck/crisis.png" alt="Guatemala hillside community" class="crisis-photo" />
    <div class="inner">
      <p class="eyebrow light">03 — The Problem</p>
      <h2><mark>2.2 million</mark> people in Guatemala live in inadequate shelter.</h2>
      <p class="crisis-body">
        That hinders their wellbeing and severely limits their potential. Globally, the scale is even larger — and growing.
      </p>
      <div class="stats-row">
        <div>
          <div class="stat-val">1.6B</div>
          <div class="stat-label">without dignified housing globally</div>
        </div>
        <div>
          <div class="stat-val">300M</div>
          <div class="stat-label">children without safe shelter</div>
        </div>
        <div>
          <div class="stat-val">3B</div>
          <div class="stat-label">will need affordable housing by 2030</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Slide 4: Our System ── -->
  <section class="slide" id="s4">
    <div class="inner">
      <p class="eyebrow">04 — Our System</p>
      <h2 class="display" style="font-size: clamp(2.25rem,5vw,4.5rem); margin-bottom: 0;">
        One house. <span style="background: var(--pop); padding: 0 0.1em;">Two materials.</span> Days to build.
      </h2>
      <div class="system-grid">
        <ol class="steps">
          <li class="step">
            <div class="step-num">01</div>
            <h3>The Sheet</h3>
            <p>Zinc or galvanized steel — available in any country, stocked in any rural hardware store.</p>
          </li>
          <li class="step">
            <div class="step-num">02</div>
            <h3>The Fold</h3>
            <p>The sheet folds into a wave — like an accordion — turning into a light, resistant structural membrane.</p>
          </li>
          <li class="step">
            <div class="step-num">03</div>
            <h3>The POP Rivet</h3>
            <p>Joins the folds without welding or specialized labor. A drill and an arm: the community builds its own house.</p>
          </li>
          <li class="step">
            <div class="step-num">04</div>
            <h3>The Assembly</h3>
            <p>Light foundations, folded walls, sheet roof. Houses standing in days — not months.</p>
          </li>
        </ol>
        <div>
          <img src="/deck/system.png" alt="Lamina POP system diagram" class="system-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Slide 5: Why Lamina POP ── -->
  <section class="slide" id="s5">
    <div class="inner">
      <p class="eyebrow light">05 — Why Lamina POP?</p>
      <h2>Built to <span>outperform</span><br>every alternative.</h2>
      <div class="why-grid">
        <div class="why-item">
          <div class="why-label">Price</div>
          <div class="why-val">34%</div>
          <div class="why-desc">cheaper than the current leading low-cost housing solution</div>
        </div>
        <div class="why-item">
          <div class="why-label">Time</div>
          <div class="why-val">4 days</div>
          <div class="why-desc">to build a complete Lamina POP home from the ground up</div>
        </div>
        <div class="why-item">
          <div class="why-label">Access</div>
          <div class="why-val">Anywhere</div>
          <div class="why-desc">prefabricated and easily transported to hard-to-reach regions</div>
        </div>
        <div class="why-item">
          <div class="why-label">Health</div>
          <div class="why-val">Safe</div>
          <div class="why-desc">eco-friendly, bright, cool, and well-ventilated by design</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Slide 6: What We Build ── -->
  <section class="slide" id="s6">
    <div class="inner">
      <p class="eyebrow">06 — What We Build</p>
      <h2>One system.<br>Every structure.</h2>
      <img src="/deck/buildings.png" alt="Social housing, commercial buildings, rural schools, luxury homes" class="build-img" />
      <div class="build-types">
        <div class="build-type"><span></span>Social Housing</div>
        <div class="build-type"><span></span>Rural Schools</div>
        <div class="build-type"><span></span>Commercial Buildings</div>
        <div class="build-type"><span></span>Luxury Homes</div>
      </div>
    </div>
  </section>

  <!-- ── Slide 7: Traction ── -->
  <section class="slide" id="s7">
    <div class="inner">
      <p class="eyebrow" style="color: rgba(0,0,0,0.45);">07 — Traction</p>
      <h2>20 years of<br>proven impact.</h2>
      <div class="traction-grid">
        <div class="t-item">
          <div class="t-val">52</div>
          <div class="t-label">Structures built</div>
        </div>
        <div class="t-item">
          <div class="t-val">300+</div>
          <div class="t-label">People benefited</div>
        </div>
        <div class="t-item">
          <div class="t-val">40%</div>
          <div class="t-label">Less cost vs conventional</div>
        </div>
        <div class="t-item">
          <div class="t-val">2004</div>
          <div class="t-label">Year founded</div>
        </div>
      </div>
      <div class="partner-row">
        <span class="partner-label">Strategic partner</span>
        <span style="width: 2rem; height: 1px; background: rgba(0,0,0,0.2);"></span>
        <span class="partner-name">Autodesk Technology Impact</span>
      </div>
    </div>
  </section>

  <!-- ── Slide 8: Closing ── -->
  <section class="slide" id="s8">
    <img src="/deck/closing.png" alt="Children in Lamina POP home" class="closing-photo" />
    <div class="inner">
      <div>
        <p class="eyebrow light">08 — Let's Talk</p>
        <h2>Shall we<br>build <em>something</em><br>together?</h2>
      </div>
      <div class="closing-footer">
        <div>
          <a href="mailto:info@laminapop.com" class="contact-email">info@laminapop.com</a>
          <p class="contact-web" style="margin-top: 0.5rem;">www.laminapop.com</p>
        </div>
        <div style="text-align: right;">
          <p style="font-size: 0.6875rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.3);">
            © 2004–2025 Lamina POP
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    // Nav dot highlighting
    const dots = document.querySelectorAll('.nav-dots a');
    const slides = document.querySelectorAll('section[id]');
    const navEl = document.getElementById('navdots');

    const darkSlides = new Set(['s2', 's5', 's8']);
    const yellowSlides = new Set(['s1', 's7']);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const id = entry.target.id;
        dots.forEach(d => d.classList.remove('active'));
        const active = document.querySelector(`.nav-dots a[href="#${id}"]`);
        if (active) active.classList.add('active');

        // Flip dot color based on slide bg
        if (darkSlides.has(id) || id === 's3') {
          navEl.classList.add('light');
        } else {
          navEl.classList.remove('light');
        }
      });
    }, { threshold: 0.5 });

    slides.forEach(s => observer.observe(s));
  </script>
</body>
</html>
